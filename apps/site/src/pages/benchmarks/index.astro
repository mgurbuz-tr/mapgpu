---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const benchmarks = (await getCollection('benchmarks')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout title="Benchmarks" description="MapGPU line rendering performance benchmarks vs other mapping libraries">
  <div class="bench-page">
    <div class="bench-header">
      <h1>Line Rendering Benchmark</h1>
      <p class="bench-subtitle">
        Choose a line count, then run a library benchmark. All pages use the same generated geometry for fair comparison.
      </p>
    </div>

    <div class="bench-controls">
      <span class="count-label">Line count:</span>
      <div class="count-picker" id="count-picker">
        <button data-n="250000">250K</button>
        <button data-n="500000">500K</button>
        <button data-n="750000">750K</button>
        <button data-n="1000000" class="active">1M</button>
      </div>
      <a href="/benchmarks/results" class="results-link">View Results Dashboard &rarr;</a>
    </div>

    <div class="bench-grid">
      {benchmarks.map((bench) => (
        <a
          class="bench-card"
          href={`/benchmarks/run/${bench.id.replace(/\.md$/, '')}?n=1000000`}
          data-base-href={`/benchmarks/run/${bench.id.replace(/\.md$/, '')}`}
        >
          <span class="bench-color" style={`background: ${bench.data.color}`} />
          <div class="bench-info">
            <span class="bench-name">{bench.data.title}</span>
            <span class="bench-tech">{bench.data.technology}</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<script>
  let activeN = 1000000;

  const stored = sessionStorage.getItem('bench-n');
  if (stored) activeN = parseInt(stored, 10);

  function updateLinks() {
    document.querySelectorAll<HTMLButtonElement>('#count-picker button').forEach((btn) => {
      btn.classList.toggle('active', parseInt(btn.dataset.n ?? '', 10) === activeN);
    });
    document.querySelectorAll<HTMLAnchorElement>('.bench-card').forEach((a) => {
      const base = a.dataset.baseHref ?? '';
      a.setAttribute('href', `${base}?n=${activeN}`);
    });
  }

  document.querySelectorAll<HTMLButtonElement>('#count-picker button').forEach((btn) => {
    btn.addEventListener('click', () => {
      activeN = parseInt(btn.dataset.n ?? '', 10);
      sessionStorage.setItem('bench-n', String(activeN));
      updateLinks();
    });
  });

  updateLinks();
</script>

<style>
  .bench-page {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 40px 24px;
  }

  .bench-header {
    margin-bottom: 32px;
  }

  .bench-header h1 {
    font-size: 1.8rem;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .bench-subtitle {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .bench-controls {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 28px;
    padding: 16px 20px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
  }

  .count-label {
    color: var(--text-muted);
    font-size: 0.88rem;
  }

  .count-picker {
    display: flex;
    gap: 6px;
  }

  .count-picker button {
    padding: 6px 14px;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    font-size: 0.85rem;
    transition: all 0.15s;
  }

  .count-picker button:hover {
    color: var(--text);
    border-color: var(--text-muted);
  }

  .count-picker button.active {
    background: var(--accent-bg);
    border-color: var(--accent);
    color: var(--accent);
    font-weight: 600;
  }

  .results-link {
    margin-left: auto;
    color: var(--accent);
    text-decoration: none;
    font-size: 0.88rem;
    white-space: nowrap;
  }

  .results-link:hover {
    text-decoration: underline;
  }

  .bench-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 14px;
  }

  .bench-card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 18px 20px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--surface);
    text-decoration: none;
    color: var(--text);
    transition: all 0.15s;
  }

  .bench-card:hover {
    border-color: var(--accent);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(255, 109, 58, 0.08);
  }

  .bench-color {
    width: 6px;
    height: 36px;
    border-radius: 3px;
    flex-shrink: 0;
  }

  .bench-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .bench-name {
    font-size: 1.05rem;
    font-weight: 600;
  }

  .bench-tech {
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .bench-page { padding: 24px 16px; }
    .bench-controls { flex-direction: column; align-items: flex-start; }
    .results-link { margin-left: 0; }
  }
</style>

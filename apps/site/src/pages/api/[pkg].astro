---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/docs.css';
import { allPackages, type PackageDoc } from '../../data/api-data';

export function getStaticPaths() {
  return allPackages.map((pkgData) => ({
    params: { pkg: pkgData.slug },
    props: { data: pkgData },
  }));
}

const { data } = Astro.props as { data: PackageDoc };

const kindColors: Record<string, string> = {
  class: 'var(--blue)',
  interface: 'var(--purple)',
  function: 'var(--green)',
  type: 'var(--orange)',
};

const kindBg: Record<string, string> = {
  class: 'rgba(88,166,255,0.15)',
  interface: 'rgba(188,140,255,0.15)',
  function: 'rgba(63,185,80,0.15)',
  type: 'rgba(255,166,87,0.15)',
};
---

<BaseLayout title={data.name}>
  <div class="container" style="padding-top: 40px; padding-bottom: 60px; max-width: 900px;">
    <a href="/api" style="font-size: 0.85rem; color: var(--text-muted);">&larr; API Reference</a>

    <h1 style="font-size: 1.8rem; font-weight: 700; margin-top: 16px; margin-bottom: 8px; font-family: var(--font-mono); color: var(--accent);">
      {data.name}
    </h1>
    <p style="color: var(--text-muted); margin-bottom: 24px;">{data.description}</p>

    <div style="margin-bottom: 32px;">
      <code style="font-size: 0.85rem; padding: 8px 14px; border-radius: 6px; background: var(--surface); border: 1px solid var(--border);">
        {data.install}
      </code>
    </div>

    <h2 style="font-size: 1.2rem; margin-bottom: 16px;">Exports</h2>

    <div class="api-grid">
      {data.classes.map(cls => (
        <a href={`/api/detail/${data.slug}/${cls.name}`} class="api-entry-card">
          <div class="entry-head">
            <span class="type-badge" style={`color:${kindColors[cls.kind]};background:${kindBg[cls.kind]}`}>
              {cls.kind}
            </span>
            <code class="entry-name">{cls.name}</code>
          </div>
          <p class="entry-desc">{cls.description}</p>
          <div class="entry-meta">
            {cls.constructor && <span class="meta-item">Constructor</span>}
            {cls.properties && cls.properties.length > 0 && (
              <span class="meta-item">{cls.properties.length} properties</span>
            )}
            {cls.methods && cls.methods.length > 0 && (
              <span class="meta-item">{cls.methods.length} methods</span>
            )}
            {cls.events && cls.events.length > 0 && (
              <span class="meta-item">{cls.events.length} events</span>
            )}
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .api-grid {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .api-entry-card {
    display: block;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 16px 18px;
    text-decoration: none;
    color: var(--text);
    transition: border-color 0.2s, transform 0.15s;
  }

  .api-entry-card:hover {
    border-color: var(--accent);
    transform: translateX(4px);
    text-decoration: none;
  }

  .entry-head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 6px;
  }

  .entry-name {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text);
  }

  .type-badge {
    font-size: 0.65rem;
    padding: 2px 8px;
    border-radius: 4px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    flex-shrink: 0;
  }

  .entry-desc {
    font-size: 0.82rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin-bottom: 8px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .entry-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .meta-item {
    font-size: 0.68rem;
    padding: 2px 8px;
    border-radius: 4px;
    background: var(--surface2);
    color: var(--text-muted);
  }
</style>

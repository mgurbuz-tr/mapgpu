---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ApiDiagram from '../../components/ApiDiagram';
---

<BaseLayout title="API Diagram — mapgpu" description="Interactive class diagram of the mapgpu public API. Explore packages, classes, methods, and their relationships." noFooter>
  <div class="diagram-page">
    <ApiDiagram client:only="react" />
  </div>
</BaseLayout>

<style is:global>
  /* ─── Page layout ─────────────────────────────────────────────────── */

  .diagram-page {
    width: 100%;
    height: calc(100vh - var(--header-h, 60px));
    overflow: hidden;
  }

  /* Astro island wrapper must pass height through */
  .diagram-page > astro-island {
    display: block;
    width: 100%;
    height: 100%;
  }

  .api-diagram-root {
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 100%;
  }

  /* ─── Filter bar ──────────────────────────────────────────────────── */

  .filter-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 20px;
    background: var(--surface, #161b22);
    border-bottom: 1px solid var(--border, #30363d);
    overflow-x: auto;
    flex-shrink: 0;
  }

  .filter-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 14px;
    border: 1px solid var(--border, #30363d);
    border-radius: 20px;
    background: transparent;
    color: var(--text-muted, #8b949e);
    font-family: var(--font-sans, Inter, sans-serif);
    font-size: 12px;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.15s ease;
  }

  .filter-pill:hover {
    border-color: var(--pill-color, #8b949e);
    color: var(--text, #e6edf3);
  }

  .filter-pill.active {
    background: var(--pill-bg, rgba(255,255,255,0.06));
    border-color: var(--pill-color, #8b949e);
    color: var(--text, #e6edf3);
  }

  .filter-pill.all {
    --pill-color: var(--accent, #ff6d3a);
    --pill-bg: rgba(255,109,58,0.1);
    font-weight: 600;
  }

  .pill-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ─── Diagram body ────────────────────────────────────────────────── */

  .diagram-body {
    display: flex;
    flex: 1;
    min-height: 0;
    position: relative;
  }

  .diagram-canvas {
    flex: 1;
    min-width: 0;
    min-height: 0;
    height: 100%;
  }

  /* ─── ReactFlow overrides ─────────────────────────────────────────── */

  .react-flow {
    --xy-background-color: var(--bg, #0d1117);
  }

  .react-flow__node {
    font-family: var(--font-sans, Inter, sans-serif);
  }

  .react-flow__controls {
    border: 1px solid var(--border, #30363d);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(0,0,0,0.4);
  }

  .react-flow__controls-button {
    background: var(--surface, #161b22);
    border-bottom: 1px solid var(--border, #30363d);
    fill: var(--text-muted, #8b949e);
    width: 28px;
    height: 28px;
  }

  .react-flow__controls-button:hover {
    background: var(--surface2, #21262d);
    fill: var(--text, #e6edf3);
  }

  .react-flow__minimap {
    border-radius: 8px !important;
  }

  .react-flow__edge-path {
    transition: stroke 0.15s;
  }

  /* ─── Package group node ──────────────────────────────────────────── */

  .pkg-group-node {
    width: 100%;
    height: 100%;
    border: 1px solid;
    border-radius: 12px;
    pointer-events: none;
  }

  .pkg-group-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
  }

  .pkg-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .pkg-name {
    font-size: 13px;
    font-weight: 700;
    font-family: var(--font-mono, 'SF Mono', monospace);
    letter-spacing: -0.02em;
  }

  /* ─── Class node ──────────────────────────────────────────────────── */

  .class-node {
    background: var(--surface, #161b22);
    border: 1px solid var(--border, #30363d);
    border-left: 4px solid;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.15s ease;
    overflow: hidden;
  }

  .class-node:hover {
    border-color: var(--text-muted, #8b949e);
    box-shadow: 0 4px 20px rgba(0,0,0,0.4);
    transform: translateY(-1px);
  }

  .class-node.selected {
    box-shadow: 0 0 0 2px var(--accent, #ff6d3a), 0 4px 20px rgba(0,0,0,0.4);
  }

  .class-node.abstract {
    border-style: dashed;
    border-left-style: solid;
  }

  .class-node .handle {
    width: 6px;
    height: 6px;
    background: var(--border, #30363d);
    border: none;
  }

  .node-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 10px;
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }

  .type-badge {
    font-size: 9px;
    font-weight: 600;
    padding: 2px 6px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    flex-shrink: 0;
    font-family: var(--font-sans, Inter, sans-serif);
  }

  .class-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--text, #e6edf3);
    font-family: var(--font-mono, 'SF Mono', monospace);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .node-methods {
    padding: 4px 10px 6px;
  }

  .method-line {
    font-size: 11px;
    color: var(--text-muted, #8b949e);
    font-family: var(--font-mono, 'SF Mono', monospace);
    padding: 1px 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: flex;
    align-items: center;
    gap: 5px;
    line-height: 1.6;
  }

  .method-line .method-icon {
    font-size: 9px;
    font-style: italic;
    font-weight: 700;
    color: var(--accent, #ff6d3a);
    opacity: 0.5;
    width: 10px;
    text-align: center;
    flex-shrink: 0;
  }

  .method-line.empty {
    font-style: italic;
    opacity: 0.4;
  }

  /* ─── Detail panel ────────────────────────────────────────────────── */

  .detail-panel {
    width: 320px;
    background: var(--surface, #161b22);
    border-left: 1px solid var(--border, #30363d);
    padding: 20px;
    overflow-y: auto;
    flex-shrink: 0;
    position: relative;
    animation: slideIn 0.2s ease;
  }

  @keyframes slideIn {
    from { transform: translateX(20px); opacity: 0; }
    to   { transform: translateX(0); opacity: 1; }
  }

  .detail-close {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border, #30363d);
    border-radius: 6px;
    background: var(--surface2, #21262d);
    color: var(--text-muted, #8b949e);
    font-size: 18px;
    cursor: pointer;
    line-height: 1;
  }

  .detail-close:hover {
    color: var(--text, #e6edf3);
    background: var(--border, #30363d);
  }

  .detail-pkg-badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 12px;
    font-family: var(--font-mono, 'SF Mono', monospace);
    margin-bottom: 12px;
  }

  .detail-title {
    font-size: 22px;
    font-weight: 700;
    color: var(--text, #e6edf3);
    font-family: var(--font-mono, 'SF Mono', monospace);
    margin: 0 0 6px;
  }

  .detail-abstract-tag {
    display: inline-block;
    font-size: 10px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 4px;
    background: rgba(188,140,255,0.15);
    color: #bc8cff;
    margin-bottom: 8px;
    text-transform: uppercase;
  }

  .detail-extends {
    font-size: 13px;
    color: var(--text-muted, #8b949e);
    margin-bottom: 16px;
  }

  .detail-parent-name {
    color: var(--accent, #ff6d3a);
    font-weight: 600;
    font-family: var(--font-mono, 'SF Mono', monospace);
  }

  .detail-section {
    margin-top: 16px;
  }

  .detail-section-title {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted, #8b949e);
    margin-bottom: 6px;
    padding-bottom: 4px;
    border-bottom: 1px solid var(--border, #30363d);
  }

  .detail-item {
    font-size: 12px;
    font-family: var(--font-mono, 'SF Mono', monospace);
    padding: 3px 0;
  }

  .detail-item.method {
    color: var(--text, #e6edf3);
  }

  .detail-item.method::before {
    content: 'f';
    font-size: 9px;
    font-style: italic;
    font-weight: 700;
    color: var(--accent, #ff6d3a);
    opacity: 0.6;
    margin-right: 8px;
  }

  .detail-item.prop {
    color: var(--blue, #58a6ff);
  }

  .detail-item.prop::before {
    content: '●';
    font-size: 7px;
    margin-right: 8px;
    opacity: 0.5;
  }

  .detail-item.rel {
    color: var(--text-muted, #8b949e);
    font-size: 11px;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .detail-item.rel strong {
    color: var(--text, #e6edf3);
    font-weight: 600;
  }

  .rel-arrow {
    font-size: 8px;
    opacity: 0.5;
  }

  /* ─── Legend ───────────────────────────────────────────────────────── */

  .diagram-legend {
    position: absolute;
    bottom: 12px;
    right: 12px;
    display: flex;
    gap: 16px;
    padding: 8px 14px;
    background: rgba(22,27,34,0.92);
    border: 1px solid var(--border, #30363d);
    border-radius: 8px;
    backdrop-filter: blur(8px);
    z-index: 5;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    color: var(--text-muted, #8b949e);
  }

  .legend-line {
    display: inline-block;
    width: 20px;
    height: 0;
    border-top: 2px solid #8b949e;
  }

  .legend-line.solid {
    border-top-style: solid;
    border-color: var(--accent, #ff6d3a);
  }

  .legend-line.dashed {
    border-top-style: dashed;
  }

  .legend-badge {
    font-size: 9px;
    font-weight: 600;
    padding: 1px 5px;
    border-radius: 3px;
    text-transform: uppercase;
  }

  .legend-badge.abstract {
    border: 1px dashed #bc8cff;
    color: #bc8cff;
  }

  .legend-badge.cls {
    border: 1px solid var(--border, #30363d);
    color: var(--text-muted, #8b949e);
  }

  /* ─── Responsive ──────────────────────────────────────────────────── */

  @media (max-width: 768px) {
    .detail-panel {
      position: absolute;
      top: 0;
      right: 0;
      bottom: 0;
      z-index: 10;
      box-shadow: -8px 0 24px rgba(0,0,0,0.5);
    }

    .filter-bar {
      padding: 8px 12px;
      gap: 6px;
    }

    .filter-pill {
      font-size: 11px;
      padding: 4px 10px;
    }

    .diagram-legend {
      bottom: 8px;
      right: 8px;
      gap: 10px;
      font-size: 10px;
    }
  }
</style>

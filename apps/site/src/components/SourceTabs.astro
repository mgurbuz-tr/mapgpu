---
interface Props {
  htmlSource?: string;
  tsSource?: string;
}

const { htmlSource, tsSource } = Astro.props;
const hasHtml = !!htmlSource;
const hasTs = !!tsSource;
---

{(hasHtml || hasTs) && (
  <div class="source-tabs">
    <div class="source-tab-nav" role="tablist">
      {hasTs && (
        <button class="source-tab-btn active" role="tab" data-tab="ts">TypeScript</button>
      )}
      {hasHtml && (
        <button class:list={['source-tab-btn', { active: !hasTs }]} role="tab" data-tab="html">HTML</button>
      )}
    </div>

    {hasTs && (
      <div class="source-tab-panel active" data-panel="ts">
        <pre><code>{tsSource}</code></pre>
      </div>
    )}

    {hasHtml && (
      <div class:list={['source-tab-panel', { active: !hasTs }]} data-panel="html">
        <pre><code>{htmlSource}</code></pre>
      </div>
    )}
  </div>
)}

<script>
  document.querySelectorAll('.source-tabs').forEach(container => {
    const buttons = container.querySelectorAll('.source-tab-btn');
    const panels = container.querySelectorAll('.source-tab-panel');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const tab = (btn as HTMLElement).dataset.tab;
        buttons.forEach(b => b.classList.remove('active'));
        panels.forEach(p => p.classList.remove('active'));
        btn.classList.add('active');
        container.querySelector(`[data-panel="${tab}"]`)?.classList.add('active');
      });
    });
  });
</script>

---
interface Props {
  command?: string;
}

const { command = 'npm install @mapgpu/core @mapgpu/layers @mapgpu/render-webgpu' } = Astro.props;
---

<div class="install-cmd" data-command={command}>
  <code>{command}</code>
  <button class="copy-btn" aria-label="Copy to clipboard">
    <svg class="icon-copy" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
    </svg>
    <svg class="icon-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2" style="display:none">
      <polyline points="20 6 9 17 4 12"/>
    </svg>
  </button>
</div>

<script>
  document.querySelectorAll('.install-cmd .copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const wrapper = btn.closest('.install-cmd') as HTMLElement;
      const cmd = wrapper.dataset.command ?? '';
      await navigator.clipboard.writeText(cmd);
      const iconCopy = btn.querySelector('.icon-copy') as SVGElement;
      const iconCheck = btn.querySelector('.icon-check') as SVGElement;
      iconCopy.style.display = 'none';
      iconCheck.style.display = 'block';
      setTimeout(() => {
        iconCopy.style.display = 'block';
        iconCheck.style.display = 'none';
      }, 2000);
    });
  });
</script>

<style>
  .install-cmd {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 14px 20px;
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }

  code { background: none; padding: 0; color: var(--text); }

  .copy-btn {
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    padding: 4px;
    border-radius: 4px;
    transition: color 0.15s;
    display: flex;
  }

  .copy-btn:hover { color: var(--accent); }
</style>

---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
const filtered = headings.filter(h => h.depth >= 2 && h.depth <= 3);
---

{filtered.length > 0 && (
  <aside class="docs-toc">
    <h4>On this page</h4>
    {filtered.map(h => (
      <a href={`#${h.slug}`} class:list={['toc-link', `depth-${h.depth}`]}>
        {h.text}
      </a>
    ))}
  </aside>
)}

---
import BaseLayout from './BaseLayout.astro';
import ExampleFrame from '../components/ExampleFrame.astro';
import SourceTabs from '../components/SourceTabs.astro';
import '../styles/examples.css';

interface Props {
  title: string;
  description: string;
  demoFile: string;
  sourceTs?: string;
  sourceHtml?: string;
  tags: string[];
}

const { title, description, demoFile, sourceTs, sourceHtml, tags } = Astro.props;
---

<BaseLayout title={title}>
  <div class="container example-detail">
    <div class="example-detail-header">
      <a href="/examples" class="example-back">&larr; Examples</a>
    </div>

    <h1>{title}</h1>
    <p style="color: var(--text-muted); margin-bottom: 20px;">{description}</p>

    <div style="display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 24px;">
      {tags.map(tag => <span class="example-tag">{tag}</span>)}
    </div>

    <ExampleFrame demoFile={demoFile} title={title} />

    <SourceTabs tsSource={sourceTs} htmlSource={sourceHtml} />
  </div>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Not Found">
  <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 60vh; text-align: center; padding: 24px;">
    <h1 style="font-size: 6rem; font-weight: 800; color: var(--accent); line-height: 1;">404</h1>
    <p style="font-size: 1.2rem; color: var(--text-muted); margin-bottom: 24px;">Page not found</p>
    <a href="/" style="padding: 10px 24px; background: var(--accent); color: var(--bg); border-radius: 8px; font-weight: 600; text-decoration: none;">
      Back to Home
    </a>
  </div>
</BaseLayout>

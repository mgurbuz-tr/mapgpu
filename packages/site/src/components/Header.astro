---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/docs/getting-started', label: 'Docs' },
  { href: '/api', label: 'API' },
  { href: '/examples', label: 'Examples' },
];

function isActive(href: string): boolean {
  if (href.startsWith('/docs')) return currentPath.startsWith('/docs');
  if (href.startsWith('/api')) return currentPath.startsWith('/api');
  if (href.startsWith('/examples')) return currentPath.startsWith('/examples');
  return false;
}
---

<header class="site-header">
  <div class="header-inner container">
    <a href="/" class="header-logo">
      <span class="logo-map">Map</span><span class="logo-gpu">GPU</span>
    </a>

    <nav class="header-nav">
      {navLinks.map(link => (
        <a href={link.href} class:list={['nav-link', { active: isActive(link.href) }]}>
          {link.label}
        </a>
      ))}
    </nav>

    <div class="header-right">
      <a href="https://github.com/mgurbuz-tr/mapgpu" class="nav-link github-link" target="_blank" rel="noopener">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        GitHub
      </a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    height: var(--header-h);
    background: rgba(13, 17, 23, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    height: 100%;
    gap: 32px;
  }

  .header-logo {
    font-size: 1.2rem;
    font-weight: 800;
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  .logo-map { color: var(--text); }
  .logo-gpu { color: var(--accent); }

  .header-nav {
    display: flex;
    gap: 4px;
  }

  .nav-link {
    padding: 6px 14px;
    font-size: 0.88rem;
    color: var(--text-muted);
    text-decoration: none;
    border-radius: 6px;
    transition: all 0.15s;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .nav-link:hover { color: var(--text); background: var(--white-soft); text-decoration: none; }
  .nav-link.active { color: var(--accent); background: var(--accent-bg); font-weight: 500; }

  .header-right { margin-left: auto; }

  .github-link svg { vertical-align: -3px; }

  @media (max-width: 640px) {
    .header-nav { gap: 0; }
    .nav-link { padding: 6px 8px; font-size: 0.82rem; }
  }
</style>

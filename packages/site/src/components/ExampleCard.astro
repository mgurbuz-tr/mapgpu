---
interface Props {
  slug: string;
  title: string;
  description: string;
  icon: string;
  category: string;
  tags: string[];
}

const { slug, title, description, icon, category, tags } = Astro.props;

const badgeClass = `badge-${category}`;
const categoryLabels: Record<string, string> = {
  'core': 'Core',
  'globe': 'Globe',
  'tools': 'Tools',
  'widgets-analysis': 'Widgets',
  'realtime-clustering': 'Realtime',
  'advanced': 'Advanced',
};
---

<a href={`/examples/${slug}`} class="example-card" data-category={category}>
  <div class="example-card-head">
    <div class="example-card-icon">{icon}</div>
    <span class="example-card-title">{title}</span>
    <span class:list={['example-card-badge', badgeClass]}>
      {categoryLabels[category] ?? category}
    </span>
  </div>
  <div class="example-card-desc">{description}</div>
  <div class="example-card-tags">
    {tags.map(tag => <span class="example-tag">{tag}</span>)}
  </div>
</a>

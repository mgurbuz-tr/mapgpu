---
interface Props {
  code: string;
  lang?: string;
  filename?: string;
}

const { code, lang = 'typescript', filename } = Astro.props;
---

<div class="code-block">
  {filename && <div class="code-filename">{filename}</div>}
  <pre><code set:html={code} /></pre>
</div>

<style>
  .code-block {
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }

  .code-filename {
    padding: 8px 16px;
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--text-muted);
    background: var(--surface2);
    border-bottom: 1px solid var(--border);
  }

  pre {
    margin: 0 !important;
    border: none !important;
    border-radius: 0 !important;
  }
</style>

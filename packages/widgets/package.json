{
  "name": "@mapgpu/widgets",
  "version": "0.0.1",
  "license": "PolyForm-Noncommercial-1.0.0",
  "description": "UI widgets: LayerList, Legend, Popup, ScaleBar, Coordinates, Search and more",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:unit": "vitest run",

    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@mapgpu/core": "workspace:*"
  },
  "devDependencies": {
    "happy-dom": "^17.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}

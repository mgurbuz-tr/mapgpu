{
  "name": "@mapgpu/milsymbol",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./milsym": {
      "types": "./dist/milsym/index.d.ts",
      "import": "./dist/milsym/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc && cp -R src/milsym/data/*.json dist/milsym/data/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@mapgpu/core": "workspace:*",
    "@mapgpu/layers": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "canvas": "^3.1.0",
    "happy-dom": "^17.4.4",
    "typescript": "~5.8.2",
    "vitest": "^3.1.1"
  },
  "license": "MIT"
}

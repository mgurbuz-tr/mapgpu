<?xml version="1.0" encoding="UTF-8"?>
<WMS_Capabilities xmlns="http://www.opengis.net/wms"
                  xmlns:xlink="http://www.w3.org/1999/xlink"
                  version="1.3.0">
  <Service>
    <Name>WMS</Name>
    <Title>Test GIS Server WMS</Title>
    <Abstract>A test WMS service for unit testing</Abstract>
    <OnlineResource xlink:href="https://gis.example.com/wms"/>
  </Service>
  <Capability>
    <Request>
      <GetCapabilities>
        <Format>text/xml</Format>
        <DCPType>
          <HTTP>
            <Get>
              <OnlineResource xlink:href="https://gis.example.com/wms?"/>
            </Get>
          </HTTP>
        </DCPType>
      </GetCapabilities>
      <GetMap>
        <Format>image/png</Format>
        <Format>image/jpeg</Format>
        <Format>image/gif</Format>
        <DCPType>
          <HTTP>
            <Get>
              <OnlineResource xlink:href="https://maps.example.com/wms/ows?"/>
            </Get>
          </HTTP>
        </DCPType>
      </GetMap>
      <GetFeatureInfo>
        <Format>application/json</Format>
        <Format>application/geo+json</Format>
        <Format>text/html</Format>
        <Format>text/plain</Format>
        <DCPType>
          <HTTP>
            <Get>
              <OnlineResource xlink:href="https://maps.example.com/wms/ows?"/>
            </Get>
          </HTTP>
        </DCPType>
      </GetFeatureInfo>
    </Request>
    <Layer>
      <Title>Root Layer</Title>
      <CRS>EPSG:4326</CRS>
      <CRS>EPSG:3857</CRS>
      <CRS>CRS:84</CRS>
      <Layer queryable="1">
        <Name>admin_boundaries</Name>
        <Title>Administrative Boundaries</Title>
        <Abstract>Country and province boundaries</Abstract>
        <CRS>EPSG:4326</CRS>
        <CRS>EPSG:3857</CRS>
        <BoundingBox CRS="EPSG:4326" minx="25.0" miny="35.0" maxx="45.0" maxy="42.0"/>
        <BoundingBox CRS="EPSG:3857" minx="2782987.0" miny="4163881.0" maxx="5009377.0" maxy="5160979.0"/>
        <Style>
          <Name>default</Name>
          <Title>Default Style</Title>
          <LegendURL width="20" height="20">
            <Format>image/png</Format>
            <OnlineResource xlink:href="https://gis.example.com/wms?REQUEST=GetLegendGraphic&amp;LAYER=admin_boundaries&amp;STYLE=default"/>
          </LegendURL>
        </Style>
        <Style>
          <Name>highlighted</Name>
          <Title>Highlighted Borders</Title>
        </Style>
      </Layer>
      <Layer queryable="1">
        <Name>roads</Name>
        <Title>Road Network</Title>
        <CRS>EPSG:4326</CRS>
        <CRS>EPSG:3857</CRS>
        <CRS>EPSG:32636</CRS>
        <BoundingBox CRS="EPSG:4326" minx="25.5" miny="35.5" maxx="44.8" maxy="41.9"/>
        <Style>
          <Name>default</Name>
          <Title>Default Road Style</Title>
        </Style>
        <Dimension name="time" units="ISO8601" default="2024-01-01T00:00:00Z">2020-01-01T00:00:00Z/2024-12-31T00:00:00Z/P1D</Dimension>
      </Layer>
      <Layer queryable="0">
        <Name>satellite_imagery</Name>
        <Title>Satellite Imagery</Title>
        <Abstract>High resolution satellite imagery</Abstract>
        <CRS>EPSG:3857</CRS>
        <BoundingBox CRS="EPSG:3857" minx="2782987.0" miny="4163881.0" maxx="5009377.0" maxy="5160979.0"/>
        <Style>
          <Name>default</Name>
          <Title>Natural Color</Title>
        </Style>
        <Layer queryable="1">
          <Name>satellite_2024</Name>
          <Title>Satellite Imagery 2024</Title>
          <CRS>EPSG:4326</CRS>
          <BoundingBox CRS="EPSG:3857" minx="2782987.0" miny="4163881.0" maxx="5009377.0" maxy="5160979.0"/>
          <Style>
            <Name>default</Name>
            <Title>Natural Color 2024</Title>
          </Style>
          <Dimension name="time" units="ISO8601" default="2024-06-01T00:00:00Z">2024-01-01T00:00:00Z/2024-12-31T00:00:00Z/P1M</Dimension>
        </Layer>
      </Layer>
    </Layer>
  </Capability>
</WMS_Capabilities>
